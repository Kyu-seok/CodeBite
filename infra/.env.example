# Database
export DB_USER=codebite
export DB_PASSWORD=<generate-with: openssl rand -base64 16>

# JWT
export JWT_SECRET=<generate-with: openssl rand -base64 32>

# Judge0
export JUDGE0_URL=http://judge0:2358
export JUDGE0_DB_PASSWORD=<generate-with: openssl rand -base64 16>

# OAuth — Google (https://console.cloud.google.com/apis/credentials)
export GOOGLE_CLIENT_ID=
export GOOGLE_CLIENT_SECRET=

# OAuth — GitHub (https://github.com/settings/developers)
export GITHUB_CLIENT_ID=
export GITHUB_CLIENT_SECRET=

# OAuth redirect (your production frontend URL)
export OAUTH_REDIRECT_BASE_URI=http://localhost:5173/auth/callback

# CORS — allowed origins for the backend API
export CORS_ALLOWED_ORIGINS=https://code-bite.com
